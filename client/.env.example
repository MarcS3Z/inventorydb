# Microsoft Entra ID (Azure AD) SSO for the Vite client.
# Set VITE_AUTH_DISABLED=true for local development without SSO.

VITE_AUTH_DISABLED=false
VITE_AZURE_CLIENT_ID="your-app-client-id"
VITE_AZURE_TENANT_ID="your-tenant-id"
# Must match an exposed API scope on the app registration
VITE_AZURE_API_SCOPE="api://your-app-client-id/access_as_user"
