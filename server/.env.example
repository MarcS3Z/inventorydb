# Copy to .env and fill in real values.
# Special characters in the DB password must be URL-encoded (e.g. ^ → %5E, $ → %24, ! → %21).

DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/DATABASE"
PORT=3001

SMTP_HOST="email-smtp.us-east-1.amazonaws.com"
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="automator@lhmpti.net"

# Microsoft Entra ID (Azure AD) SSO
# Set AUTH_DISABLED=true for local development without SSO.
AUTH_DISABLED=false
AZURE_TENANT_ID="your-tenant-id"
AZURE_CLIENT_ID="your-app-client-id"
# Audience for access tokens (usually api://YOUR_CLIENT_ID)
AZURE_AUDIENCE="api://your-app-client-id"
