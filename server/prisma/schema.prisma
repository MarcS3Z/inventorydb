generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Item {
  id          Int      @id @default(autoincrement())
  name        String
  description String?  @db.Text
  sku         String   @unique
  quantity    Int      @default(0)
  priceCents  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Fields from IT Inventory-PTI.xlsx (PTI In Use / PT Available / PT Removed)
model Inventory {
  id           Int       @id @default(autoincrement())
  assetId      String    @unique // spreadsheet "ID" (serial / asset tag)
  category     String?
  manufacturer String?
  type         String?
  issued       DateTime?
  location     String?
  lastName     String?
  firstName    String?
  notes        String?   @db.Text
  status       String?
  lastCheckIn  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("inventory")
}

model Location {
  id        Int    @id @default(autoincrement())
  shortcode String @unique
  name      String

  @@map("locations")
}

model Category {
  id          Int    @id @default(autoincrement())
  category    String @unique
  ticketEmail String

  @@map("categories")
}
